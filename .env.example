# PinAffiliate - copy to .env and fill

# Amazon PAAPI optional; scrape fallback works without it
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=newdro04-21

# Pinterest
PINTEREST_ACCESS_TOKEN=pina_your_token_here
BOARD_TECH=your_board_id
BOARD_HOME=your_board_id
BOARD_FITNESS=your_board_id
BOARD_DEALS=your_board_id

# Gemini
GEMINI_API_KEY=your_gemini_key_here

# Optional Hugging Face intelligence signals
HUGGINGFACE_API_TOKEN=
HF_TEXT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
HF_ZERO_SHOT_MODEL=facebook/bart-large-mnli
HF_IMAGE_MODEL=google/vit-base-patch16-224
HF_MAX_AI_CALLS=24
AI_MIN_PRODUCT_SCORE=55

# Telegram alerts optional
TELEGRAM_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id_number

# Publishing limits
MAX_PINS_PER_DAY=8
MIN_DELAY_SEC=180
MAX_DELAY_SEC=420
